OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=8192
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

APP_STORAGE_DIR=./storage
APP_UPLOAD_DIR=./uploads
APP_OUTPUT_DIR=./outputs
APP_DATABASE_URL=sqlite:///./storage/novel_deconstructor.db

MAX_UPLOAD_SIZE_MB=500
MAX_CHAPTER_CHARS=12000
CHUNK_OVERLAP_CHARS=800
DEFAULT_CONCURRENCY=1
ALLOW_ABSOLUTE_OUTPUT_PATH=false
ENABLE_DIRECTORY_PICKER=true

OH_STORY_REPO_URL=https://github.com/HeRiki/oh-story-codex.git

