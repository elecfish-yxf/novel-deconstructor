OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=8192

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
