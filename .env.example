OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=8192

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

DOUBAO_API_KEY=
ARK_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-pro-260215

APP_STORAGE_DIR=./storage
APP_UPLOAD_DIR=./uploads
APP_OUTPUT_DIR=./outputs
APP_KNOWLEDGE_DIR=./storage/knowledge
APP_DATABASE_URL=sqlite:///./storage/novel_deconstructor.db
# For MySQL / RDS (requires: pip install pymysql cryptography):
# APP_DATABASE_URL=mysql+pymysql://USER:PASSWORD@MYSQL_HOST:3306/novel_deconstructor_prod?charset=utf8mb4
# ECS + Aliyun RDS intranet example:
# APP_DATABASE_URL=mysql+pymysql://<user>:<url_encoded_password>@<rds-internal-host>:3306/<database>?charset=utf8mb4
APP_REQUIRE_AUTH=false
APP_AUTH_SESSION_DAYS=30
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

MAX_UPLOAD_SIZE_MB=20
MAX_CHAPTER_CHARS=12000
CHUNK_OVERLAP_CHARS=800
KNOWLEDGE_CHUNK_SIZE=900
KNOWLEDGE_CHUNK_OVERLAP=120

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=novel_knowledge
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine

# Retrieval
# Use hybrid after Qdrant and embeddings are configured.
RETRIEVAL_MODE=keyword
RETRIEVAL_TOP_K=12
RETRIEVAL_CANDIDATE_K=80
RETRIEVAL_KEYWORD_WEIGHT=0.35
RETRIEVAL_VECTOR_WEIGHT=0.65
RETRIEVAL_SCOPE_FILTER_ENABLED=true
RETRIEVAL_DIVERSITY_ENABLED=true
RETRIEVAL_MAX_PER_SOURCE=3
RETRIEVAL_MAX_PER_CARD_TYPE=5

# Embedding
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_VECTOR_SIZE=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=60

DEFAULT_CONCURRENCY=1
ALLOW_ABSOLUTE_OUTPUT_PATH=false
ENABLE_DIRECTORY_PICKER=true

OH_STORY_REPO_URL=https://github.com/HeRiki/oh-story-codex.git
